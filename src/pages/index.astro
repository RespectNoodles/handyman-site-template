---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #f5f7fa;
        color: #333;
        margin: 0; padding: 0;
      }
      main {
        max-width: 900px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      h1 {
        color: #007acc;
        font-size: 2.8rem;
        margin-bottom: 0.5rem;
        text-align: center;
      }
      p.intro {
        font-size: 1.2rem;
        text-align: center;
        max-width: 700px;
        margin: 0 auto 2rem;
        line-height: 1.6;
      }
      section {
        background: white;
        border-radius: 8px;
        padding: 1.8rem 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 3px 7px rgba(0,0,0,0.1);
      }
      h2 {
        color: #004a99;
        margin-bottom: 1rem;
        font-weight: 600;
        border-bottom: 2px solid #007acc;
        padding-bottom: 0.4rem;
      }
      ul.socials {
        display: flex;
        justify-content: center;
        gap: 1.8rem;
        padding: 0;
        list-style: none;
        margin-top: 1rem;
      }
      ul.socials li a {
        color: #007acc;
        text-decoration: none;
        font-size: 1.8rem;
        transition: color 0.3s ease;
      }
      ul.socials li a:hover {
        color: #004a99;
      }
      .contact-info p {
        font-size: 1.1rem;
        margin: 0.4rem 0;
        text-align: center;
      }
      .btn-contact {
        display: block;
        width: max-content;
        margin: 1.5rem auto 0;
        padding: 0.7rem 2.5rem;
        background: #007acc;
        color: white;
        border-radius: 25px;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 4px 10px rgba(0,122,204,0.4);
        transition: background-color 0.3s ease;
      }
      .btn-contact:hover {
        background: #005fa3;
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <h1>Official Site of Handyman Cruz</h1>
      <p class="intro">
        Welcome to the home of reliable, affordable handyman services in your local area. I'm Cruz, a skilled and approachable tradesman committed to getting the job done right — whether it's fixing, building, installing, or improving.
      </p>

      <section class="experience">
        <h2>Why Choose Me?</h2>
        <p>
          • Over 5 years of hands-on trade experience<br />
          • Fully insured and safety focused<br />
          • Transparent pricing and no hidden costs<br />
          • Friendly, punctual, and trustworthy service
        </p>
      </section>

      <section class="contact-info">
        <h2>Contact Me</h2>
        <p>📞 Phone: <a href="tel:+61427706676">+61 427 706 676</a></p>
        <p>📧 Email: <a href="mailto:handymancruz3@gmail.com">handymancruz3@gmail.com</a></p>
        <a href="mailto:handymancruz3@gmail.com" class="btn-contact">Get in Touch</a>
      </section>

      <section class="socials">
        <h2>Follow Me</h2>
        <ul class="socials" role="list">
          <li><a href="https://www.facebook.com/yourprofile" target="_blank" rel="noopener" aria-label="Facebook">🔵 Facebook</a></li>
          <li><a href="https://www.instagram.com/yourprofile" target="_blank" rel="noopener" aria-label="Instagram">📸 Instagram</a></li>
          <li><a href="https://www.linkedin.com/in/yourprofile" target="_blank" rel="noopener" aria-label="LinkedIn">🔗 LinkedIn</a></li>
        </ul>
      </section>
    </main>

    <Footer />
  </body>
</html>
